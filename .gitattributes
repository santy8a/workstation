# Default: normalize text files

* text=auto

# =========================

# Linux Scripts

# =========================

*.sh text eol=lf
*.bash text eol=lf

# =========================

# PowerShell

# =========================

*.ps1 text eol=crlf
*.psm1 text eol=crlf

# =========================

# Documentation

# =========================

*.md text eol=lf
*.txt text eol=lf

# =========================

# Configuration Files

# =========================

*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.tf text eol=lf
*.tfvars text eol=lf
*.hcl text eol=lf

# =========================

# Source Code

# =========================

*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf

# =========================

# VSCode

# =========================

.vscode/* text eol=lf

# =========================

# Draw.io

# =========================

*.drawio text eol=lf

# =========================

# Binary Files

# =========================

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.tgz binary
*.7z binary
*.exe binary
*.dll binary
